{
  "name": "@codecrafters/git",
  "description": "Build your own Git challenge, from CodeCrafters",
  "type": "module",
  "scripts": {
    "setup": "bash scripts/setup.sh",
    "dev": "bun run app/main.ts",
    "clean": "rimraf bun.lock node_modules .repos .cursor",
    "typecheck": "tsc -b tsconfig.json",
    "format:fix": "dprint fmt",
    "format:check": "dprint check",
    "lint:check": "oxlint && bun run typecheck",
    "lint:fix": "oxlint --fix"
  },
  "dependencies": {
    "@effect/platform-bun": "beta",
    "effect": "beta"
  },
  "devDependencies": {
    "@effect/vitest": "0.29.0",
    "@effect/language-service": "0.80.0",
    "@types/bun": "1.3.10",
    "dprint": "0.53.0",
    "oxlint": "1.56.0",
    "rimraf": "6.1.3",
    "typescript": "5.9.3"
  },
  "engines": {
    "bun": "1.3.10"
  },
  "packageManager": "bun@1.3.10"
}
