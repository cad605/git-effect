{
  "name": "@codecrafters/git",
  "description": "Build your own Git challenge, from CodeCrafters",
  "type": "module",
  "scripts": {
    "dev": "bun run app/main.ts",
    "clean": "rimraf bun.lock node_modules apps/*/node_modules packages/*/node_modules .turbo apps/*/.turbo packages/*/.turbo",
    "format:fix": "oxfmt",
    "format:check": "oxfmt --check",
    "lint:check": "oxlint && dprint check",
    "lint:fix": "oxlint --fix && dprint fmt"
  },
  "dependencies": {
    "@effect/platform-bun": "beta",
    "effect": "beta"
  },
  "devDependencies": {
    "@effect/language-service": "0.80.0",
    "@types/bun": "1.3.10",
    "dprint": "0.53.0",
    "oxfmt": "0.41.0",
    "oxlint": "1.56.0",
    "rimraf": "6.1.3",
    "typescript": "5.9.3"
  },
  "engines": {
    "bun": "1.3.10"
  },
  "packageManager": "bun@1.3.10"
}
